# ── AetherGuard Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.2

# ── Simulator ─────────────────────────────────────────────────────────────────
SIMULATOR_SEED=42
SIMULATOR_WARMUP_TICKS=30
SIMULATOR_POLL_INTERVAL=5.0
SCENARIO_DIR=core/simulator/scenarios

# ── Anomaly Detection ─────────────────────────────────────────────────────────
IF_CONTAMINATION=0.05
FLAP_THRESHOLD=2

# ── Remediation ───────────────────────────────────────────────────────────────
AUTO_REMEDIATE=false
RUN_CHAOS=true
APPROVAL_TIMEOUT_SECONDS=300

# ── AWS (optional — only needed for real AWS calls) ───────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
